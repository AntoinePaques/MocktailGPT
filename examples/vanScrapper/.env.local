# VanScrapper specific (optional overrides)
SWAGGER_PATH=./swagger.yaml

OPENAI_API_KEY=sk-xxxxxxxxxxxxxxx
OPENAI_MODEL_FALLBACK=gpt-4o
OPENAI_DEFAULT_TEMPERATURE=0.7
OPENAI_API_BASE_URL="https://api.openai.com/v1"

# Prompt spécifique pour VanScrapper
OPENAI_BASE_PROMPT="You are a van conversion and resale expert, with a comprehensive understanding of van models and their evolution from 1950 to today. You provide precise, concise, and actionable information in strict JSON format, tailored to the needs of modern vanlifers and professionals."
