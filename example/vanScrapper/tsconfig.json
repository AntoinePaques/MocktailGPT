{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "outDir": "./dist",
    "rootDir": "./",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true,
    "lib": ["ES2022", "DOM"], // <-- ajoute DOM et ES2022 ici
    "types": ["node"] // <-- ajoute node ici
  },
  "include": ["src", "generated"]
}
